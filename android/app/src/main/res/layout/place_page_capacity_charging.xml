<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ll__place_capacity_charging"
    style="@style/PlacePageItemFrame"
    tools:background="#4000FFFF"
    tools:visibility="visible">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv__place_capacity_charging"
        style="@style/PlacePageMetadataIcon"
        app:srcCompat="@drawable/ic_bookmark_charging_station" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tv__place_capacity_charging"
        android:textAlignment="viewStart"
        style="@style/PlacePageMetadataText"
        tools:text="@string/capacity_charging" />
</LinearLayout>
