<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="@dimen/margin_base"
    android:layout_marginBottom="@dimen/margin_base"
    android:orientation="vertical"
    android:paddingStart="@dimen/altitude_chart_container_padding_left"
    android:paddingEnd="@dimen/altitude_chart_container_padding_left">

    <include
        layout="@layout/bottom_sheet_handle" />

    <LinearLayout
        android:id="@+id/directions_header"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="vertical">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/planning_route_preview"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="@dimen/divider_height"
            android:background="?dividerHorizontal" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/directions_step_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fadeScrollbars="true"
        android:scrollbarSize="6dp"
        android:scrollbarStyle="outsideOverlay"
        android:scrollbarThumbVertical="?android:attr/textColorSecondary"
        android:scrollbars="vertical"
        tools:itemCount="5"
        tools:listitem="@layout/directions_step_item" />

</LinearLayout>